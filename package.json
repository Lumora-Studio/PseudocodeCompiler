{
  "name": "igcse-pseudocode-compiler",
  "version": "0.1.9",
  "private": true,
  "description": "Pseudocode Compiler — monorepo with shared compiler, web/desktop, and mobile apps.",
  "author": "Alex",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @igcse/web dev",
    "dev:web": "pnpm --filter @igcse/web dev:web",
    "open:desktop": "pnpm --filter @igcse/web open:electron",
    "dist": "pnpm --filter @igcse/web dist",
    "dist:unsigned": "pnpm --filter @igcse/web dist:unsigned",
    "pack": "pnpm --filter @igcse/web pack",
    "ios:ipad26": "pnpm --filter @igcse/mobile ios:ipad26",
    "ios:preview": "pnpm --filter @igcse/mobile ios:preview",
    "ios:production": "pnpm --filter @igcse/mobile ios:production",
    "ios:testflight": "pnpm --filter @igcse/mobile ios:testflight",
    "build": "pnpm --filter @igcse/web build",
    "test": "pnpm -r --if-present run test",
    "test:compiler": "pnpm --filter @igcse/compiler test",
    "test:web": "pnpm --filter @igcse/web test",
    "typecheck:mobile": "pnpm --filter @igcse/mobile typecheck",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint"
  },
  "devDependencies": {
    "convex": "^1.36.1"
  },
  "pnpm": {
    "overrides": {
      "minimatch@^3.0.0": "3.1.4",
      "minimatch@^9.0.0": "9.0.7",
      "minimatch@^10.0.0": "10.2.3",
      "rollup": "^4.59.0"
    },
    "onlyBuiltDependencies": [
      "dtrace-provider",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
