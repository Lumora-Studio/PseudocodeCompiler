{
  "name": "@igcse/web",
  "version": "0.1.8",
  "private": true,
  "description": "Next.js + Electron web/desktop app for IGCSE pseudocode compiler.",
  "author": "Alex",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "cross-env NEXT_PUBLIC_RESET_WORKSPACE_ON_DEV=1 next dev",
    "dev:electron": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 NEXT_PUBLIC_RESET_WORKSPACE_ON_DEV=1 electron .",
    "dev:electron:devtools": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 ELECTRON_OPEN_DEVTOOLS=1 NEXT_PUBLIC_RESET_WORKSPACE_ON_DEV=1 electron .",
    "build": "next build",
    "build:electron-web": "cross-env BUILD_TARGET=electron next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build:electron-web && node scripts/check-macos-signing.cjs && electron-builder --mac dmg",
    "dist:unsigned": "npm run build:electron-web && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "pack": "npm run build:electron-web && electron-builder --dir"
  },
  "dependencies": {
    "@igcse/compiler": "*",
    "@igcse/workspace": "*",
    "@monaco-editor/react": "^4.7.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "37.10.3",
    "electron-builder": "^26.0.20",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "minimatch@^3.0.0": "3.1.4",
    "minimatch@^9.0.0": "9.0.7",
    "minimatch@^10.0.0": "10.2.3",
    "rollup": "^4.59.0"
  },
  "build": {
    "appId": "com.alex.igcsepseudocodecompiler",
    "productName": "IGCSE Pseudocode Compiler",
    "electronVersion": "37.10.3",
    "electronDist": "../../node_modules/electron/dist",
    "files": [
      {
        "from": "electron",
        "to": "electron",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".",
        "filter": [
          "package.json"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "electron/assets/icon.icon",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "icon": "electron/assets/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
